{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Provisioning a single S3 Bucket for Medallion Architecture (Bronze, Silver, Gold folders).",
  "Parameters": {
    "ProjectName": {
      "Type": "String",
      "Default": "sentinel-fraud-detection"
    }
  },
  "Resources": {
    "MedallionDataLake": {
      "Type": "AWS::S3::Bucket",
      "DeletionPolicy": "Delete",
      "Properties": {
        "BucketName": {
          "Fn::Sub": "${ProjectName}-datalake"
        },
        "VersioningConfiguration": {
          "Status": "Enabled"
        },
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "AES256"
              }
            }
          ]
        },
        "LifecycleConfiguration": {
          "Rules": [
            {
              "Id": "BronzeRawRetention",
              "Status": "Enabled",
              "Prefix": "bronze/",
              "Transitions": [
                {
                  "TransitionInDays": 90,
                  "StorageClass": "GLACIER"
                }
              ],
              "Expiration": {
                "Days": 365
              }
            },
            {
              "Id": "SilverValidatedRetention",
              "Status": "Enabled",
              "Prefix": "silver/",
              "Transitions": [
                {
                  "TransitionInDays": 180,
                  "StorageClass": "GLACIER"
                }
              ],
              "Expiration": {
                "Days": 730
              }
            },
            {
              "Id": "GoldEnrichedRetention",
              "Status": "Enabled",
              "Prefix": "gold/",
              "Transitions": [
                {
                  "TransitionInDays": 90,
                  "StorageClass": "GLACIER"
                }
              ],
              "Expiration": {
                "Days": 180
              }
            },
            {
              "Id": "TempFileCleanup",
              "Status": "Enabled",
              "Prefix": "temp/",
              "Expiration": {
                "Days": 7
              }
            }
          ]
        },
        "Tags": [
          {
            "Key": "Environment",
            "Value": "Production"
          },
          {
            "Key": "Project",
            "Value": "Sentinel-Fraud-Detection"
          },
          {
            "Key": "Architecture",
            "Value": "Medallion"
          }
        ]
      }
    }
  },
  "Outputs": {
    "DataLakeBucketName": {
      "Value": {
        "Ref": "MedallionDataLake"
      },
      "Export": {
        "Name": "Sentinel-DataLakeBucket"
      }
    }
  }
}